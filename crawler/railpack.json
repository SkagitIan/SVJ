{
  "$schema": "https://schema.railpack.com",
  "provider": "python",
  "steps": {
    "playwright": {
      "inputs": [
        {
          "step": "build"
        }
      ],
      "commands": [
        "PLAYWRIGHT_BROWSERS_PATH=/app/.cache/ms-playwright python -m playwright install chromium"
      ],
      "deployOutputs": [
        {
          "include": [
            ".cache/ms-playwright"
          ]
        }
      ]
    }
  },
  "deploy": {
    "aptPackages": [
      "libglib2.0-0",
      "libnss3",
      "libnspr4",
      "libatk1.0-0",
      "libatk-bridge2.0-0",
      "libcups2",
      "libdbus-1-3",
      "libdrm2",
      "libxkbcommon0",
      "libxcomposite1",
      "libxdamage1",
      "libxfixes3",
      "libxrandr2",
      "libgbm1",
      "libasound2",
      "libpango-1.0-0",
      "libcairo2"
    ],
    "variables": {
      "PLAYWRIGHT_BROWSERS_PATH": "/app/.cache/ms-playwright"
    },
    "startCommand": "gunicorn app:app --bind 0.0.0.0:${PORT:-5050} --workers 1 --threads 8 --timeout 180"
  }
}
