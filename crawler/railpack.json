{
  "$schema": "https://schema.railpack.com",
  "provider": "python",
  "steps": {
    "playwright": {
      "inputs": [
        {
          "step": "build"
        }
      ],
      "commands": [
        "python -m playwright install --with-deps chromium"
      ]
    }
  },
  "deploy": {
    "inputs": [
      {
        "step": "playwright"
      }
    ],
    "startCommand": "gunicorn app:app --bind 0.0.0.0:${PORT:-5050} --workers 1 --threads 8 --timeout 180"
  }
}
